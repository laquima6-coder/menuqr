# ══════════════════════════════════════════
#  MenuQR — Variables de entorno
#  Copiá este archivo como .env y completá
#  con tus claves reales de Supabase
# ══════════════════════════════════════════

# Supabase — obtenelas en: supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://XXXXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# PIN de acceso al panel Super Admin (/superadmin)
VITE_SUPER_PIN=tu_pin_secreto_aqui

# ── IMPORTANTE ────────────────────────────
# El archivo .env NUNCA se sube a GitHub
# En Vercel las agregás en:
# Project Settings → Environment Variables

# TomTom Maps API — para el módulo de Delivery
# Obtenés la key gratis en: developer.tomtom.com → Create App → Copy Key
VITE_TOMTOM_KEY=tu_tomtom_api_key_aqui
